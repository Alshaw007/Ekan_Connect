
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information, account balance, and settings.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the user (UID from Auth)." },
        "name": { "type": "string", "description": "The display name of the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "handle": { "type": "string", "description": "The user's unique handle (e.g., @username)." },
        "avatar": { "type": "string", "description": "URL to the user's avatar image." },
        "location": { "type": "string", "description": "The user's current location node." },
        "bio": { "type": "string", "description": "The user's biography." },
        "interests": { "type": "array", "items": { "type": "string" }, "description": "List of user interests." },
        "balance": { "type": "number", "description": "The user's current wallet balance." },
        "joinedAt": { "type": "string", "format": "date-time", "description": "When the user joined the grid." },
        "isVerified": { "type": "boolean", "description": "Whether the user is verified." },
        "trustScore": { "type": "integer", "description": "The user's trust score on the grid." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role." },
        "theme": { "type": "string", "enum": ["light", "dark", "system"], "description": "User's theme preference." },
        "blockedUsers": { "type": "array", "items": { "type": "string" }, "description": "List of blocked user UIDs." },
        "following": { "type": "array", "items": { "type": "string" }, "description": "List of UIDs the user follows." },
        "followers": { "type": "array", "items": { "type": "string" }, "description": "List of UIDs following the user." },
        "nativeLanguage": { "type": "string", "description": "User's native language." },
        "learningLanguages": { "type": "array", "items": { "type": "string" }, "description": "Languages the user is learning." }
      },
      "required": ["id", "name", "email", "handle", "balance", "joinedAt", "role"]
    },
    "Community": {
      "title": "Community",
      "description": "A group or community on the grid.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the community." },
        "name": { "type": "string", "description": "The name of the community." },
        "description": { "type": "string", "description": "The description of the community." },
        "avatar": { "type": "string", "description": "URL to the community's avatar image." },
        "memberCount": { "type": "integer", "description": "Number of members in the community." },
        "isPrivate": { "type": "boolean", "description": "Whether the community is private." },
        "category": { "type": "string", "description": "The category of the community." }
      },
      "required": ["id", "name", "description", "memberCount", "isPrivate"]
    },
    "VoiceRoom": {
      "title": "Voice Room",
      "description": "A live audio room.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the voice room." },
        "hostId": { "type": "string", "description": "The UID of the room host." },
        "hostName": { "type": "string", "description": "The name of the room host." },
        "title": { "type": "string", "description": "The title of the voice room." },
        "participantCount": { "type": "integer", "description": "Number of participants in the room." },
        "isLive": { "type": "boolean", "description": "Whether the room is currently live." },
        "startedAt": { "type": "string", "format": "date-time", "description": "When the room was started." }
      },
      "required": ["id", "hostId", "hostName", "title", "participantCount", "isLive", "startedAt"]
    },
    "LiveStream": {
      "title": "Live Stream",
      "description": "A live video stream.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the live stream." },
        "hostId": { "type": "string", "description": "The UID of the stream host." },
        "hostName": { "type": "string", "description": "The name of the stream host." },
        "hostAvatar": { "type": "string", "description": "URL to the host's avatar." },
        "title": { "type": "string", "description": "The title of the live stream." },
        "viewerCount": { "type": "integer", "description": "Number of viewers in the stream." },
        "isLive": { "type": "boolean", "description": "Whether the stream is currently live." },
        "startedAt": { "type": "string", "format": "date-time", "description": "When the stream was started." },
        "category": { "type": "string", "description": "The category of the stream." }
      },
      "required": ["id", "hostId", "hostName", "title", "viewerCount", "isLive", "startedAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A social post on the feed.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the post." },
        "authorId": { "type": "string", "description": "The UID of the post author." },
        "authorName": { "type": "string", "description": "The name of the post author." },
        "content": { "type": "string", "description": "The text content of the post." },
        "thumbnail": { "type": "string", "description": "URL to the post's media thumbnail." },
        "likes": { "type": "integer", "description": "Number of likes on the post." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the post was created." }
      },
      "required": ["id", "authorId", "authorName", "content", "likes", "timestamp"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a chat thread.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the message." },
        "senderId": { "type": "string", "description": "The UID of the sender." },
        "receiverId": { "type": "string", "description": "The UID of the receiver (user or group)." },
        "text": { "type": "string", "description": "The text content of the message." },
        "type": { "type": "string", "enum": ["text", "image", "video", "file", "money", "voice_memo", "video_memo", "call"], "description": "The type of message." },
        "mediaUrl": { "type": "string", "description": "URL to any media attachment." },
        "fileName": { "type": "string", "description": "Name of the attached file." },
        "amount": { "type": "number", "description": "Amount of money sent (if type is money)." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent." },
        "status": { "type": "string", "enum": ["sent", "delivered", "read"], "description": "Message delivery status." },
        "callId": { "type": "string", "description": "The call ID if type is call." }
      },
      "required": ["id", "senderId", "receiverId", "type", "timestamp"]
    },
    "ChatThread": {
      "title": "Chat Thread",
      "description": "Metadata for a direct or group chat thread.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the thread." },
        "type": { "type": "string", "enum": ["direct", "group"], "description": "The type of thread." },
        "name": { "type": "string", "description": "The name of the group chat." },
        "avatar": { "type": "string", "description": "The avatar of the group chat." },
        "members": { "type": "array", "items": { "type": "string" }, "description": "List of member UIDs." },
        "lastMessage": { "type": "string", "description": "The last message text." },
        "lastMessageSenderId": { "type": "string", "description": "The UID of the last message sender." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the last message was sent." },
        "typing": { "type": "object", "description": "Map of UID to typing status." }
      },
      "required": ["id", "type", "members", "timestamp"]
    },
    "Call": {
      "title": "Call",
      "description": "A record of an audio or video call.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the call." },
        "callerId": { "type": "string", "description": "The UID of the caller." },
        "receiverId": { "type": "string", "description": "The UID of the receiver." },
        "type": { "type": "string", "enum": ["audio", "video"], "description": "The type of call." },
        "status": { "type": "string", "enum": ["ringing", "ongoing", "ended", "missed", "rejected"], "description": "The call status." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the call started." },
        "duration": { "type": "number", "description": "The duration of the call in seconds." }
      },
      "required": ["id", "callerId", "receiverId", "type", "status", "timestamp"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A wallet transaction record.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the transaction." },
        "userId": { "type": "string", "description": "The UID of the user this transaction belongs to." },
        "amount": { "type": "number", "description": "The transaction amount." },
        "type": { "type": "string", "enum": ["inbound", "outbound"], "description": "Direction of the transaction." },
        "description": { "type": "string", "description": "Description of the transaction." },
        "status": { "type": "string", "enum": ["completed", "pending"], "description": "Transaction status." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the transaction occurred." }
      },
      "required": ["id", "userId", "amount", "type", "description", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of social feed posts."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific chat thread."
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transaction history for a user."
    },
    "/threads/{threadId}": {
      "schema": "ChatThread",
      "description": "Metadata for chat threads."
    },
    "/calls/{callId}": {
      "schema": "Call",
      "description": "Call records and signaling."
    },
    "/communities/{communityId}": {
      "schema": "Community",
      "description": "Collection of communities."
    },
    "/voice_rooms/{roomId}": {
      "schema": "VoiceRoom",
      "description": "Active voice rooms."
    },
    "/live_streams/{streamId}": {
      "schema": "LiveStream",
      "description": "Active live streams."
    }
  }
}
